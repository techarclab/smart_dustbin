{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ConnectAsSelf",
      "Effect": "Allow",
      "Action": "iot:Connect",
      "Resource": "arn:aws:iot:eu-north-1:978236789991:client/${iot:Connection.Thing.ThingName}"
    },
    {
      "Sid": "PublishOwnTopics",
      "Effect": "Allow",
      "Action": "iot:Publish",
      "Resource": [
        "arn:aws:iot:eu-north-1:978236789991:topic/smartbin/${iot:Connection.Thing.Attributes[bin_id]}/telemetry",
        "arn:aws:iot:eu-north-1:978236789991:topic/smartbin/${iot:Connection.Thing.Attributes[bin_id]}/alert",
        "arn:aws:iot:eu-north-1:978236789991:topic/smartbin/${iot:Connection.Thing.Attributes[bin_id]}/status"
      ]
    },
    {
      "Sid": "SubscribeOwnCmd",
      "Effect": "Allow",
      "Action": "iot:Subscribe",
      "Resource": [
        "arn:aws:iot:eu-north-1:978236789991:topicfilter/smartbin/${iot:Connection.Thing.Attributes[bin_id]}/cmd"
      ]
    },
    {
      "Sid": "ReceiveOwnCmd",
      "Effect": "Allow",
      "Action": "iot:Receive",
      "Resource": [
        "arn:aws:iot:eu-north-1:978236789991:topic/smartbin/${iot:Connection.Thing.Attributes[bin_id]}/cmd"
      ]
    }
  ]
}
